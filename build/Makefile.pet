include build/common.mk

TARGET   = pet
OUT      = dungeon-pet.prg
SOURCES  = $(GAME_SOURCES) platform/plat_pet.c
CC       = cl65
CFLAGS   = -t $(TARGET) -O -Cl -I platform -I game

all: $(OUT)

$(OUT): $(SOURCES)
	$(CC) $(CFLAGS) -o $@ $(SOURCES)

clean:
	rm -f $(OUT) $(SOURCES:.c=.o)

run: $(OUT)
	xpet $(OUT)

.PHONY: all clean run
