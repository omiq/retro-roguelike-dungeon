include build/common.mk

TARGET   = bbc
OUT      = dungeon-bbc.ssd
SOURCES  = $(GAME_SOURCES) platform/plat_bbc.c
CC       = cl65
CFLAGS   = -t $(TARGET) -O -Cl -I platform -I game

all: $(OUT)

$(OUT): $(SOURCES)
	$(CC) $(CFLAGS) -o $@ $(SOURCES)

clean:
	rm -f $(OUT) $(SOURCES:.c=.o)

.PHONY: all clean
